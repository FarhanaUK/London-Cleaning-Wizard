rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bookings — admin read only (writes go through cloud functions with admin SDK)
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Customers — admin read only
    match /customers/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User preferences (theme etc) — each user can only read/write their own
    match /userPrefs/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Staff — admin only
    match /staff/{staffId} {
      allow read, write: if request.auth != null;
    }

    // Expenses, fixed costs, supplies — admin only
    match /expenses/{id} {
      allow read, write: if request.auth != null;
    }
    match /fixedCosts/{id} {
      allow read, write: if request.auth != null;
    }
    match /supplies/{id} {
      allow read, write: if request.auth != null;
    }

    // Settings (budgets etc) — admin only
    match /settings/{id} {
      allow read, write: if request.auth != null;
    }

    // Abandonment stats — admin read + delete; writes via cloud functions only
    match /abandonmentStats/{id} {
      allow read, delete: if request.auth != null;
      allow create, update: if false;
    }

    // Booking funnel — public write (unauthenticated visitors), admin read + delete
    match /bookingFunnel/{id} {
      allow read, delete: if request.auth != null;
      allow create, update: if true;
    }

    // Pending bookings — admin read only (writes/deletes via cloud functions)
    match /pendingBookings/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Promotions — admin full access; public read (booking flow needs it unauthenticated)
    match /promotions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Scheduler logs — admin read only (writes via cloud functions)
    match /schedulerLogs/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Signature Touch — 100ml distribution log and price history — admin only
    match /stDistributions/{id} {
      allow read, write: if request.auth != null;
    }
    match /stPriceHistory/{id} {
      allow read, write: if request.auth != null;
    }

    // Marketing dashboard data — admin only
    match /mkt_data/{docId} {
      allow read, write: if request.auth != null;
    }

    // Ad spend entries — admin only
    match /marketingSpend/{id} {
      allow read, write: if request.auth != null;
    }

    // Everything else — deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
